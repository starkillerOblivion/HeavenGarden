<Window x:Class="HeavenGarden.Windows.EditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HeavenGarden.Windows"
        mc:Ignorable="d"
        Title="EditUserWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBlock Text="Логин:"/>
        <TextBox x:Name="tbUsername"/>
        <TextBlock Text="Пароль (оставьте пустым, если не менять):"/>
        <PasswordBox x:Name="pbPassword"/>
        <TextBlock Text="Email:"/>
        <TextBox x:Name="tbEmail"/>
        <TextBlock Text="Полное имя:"/>
        <TextBox x:Name="tbFullName"/>
        <TextBlock Text="Роль:"/>
        <ComboBox x:Name="cmbRole" DisplayMemberPath="RoleName" SelectedValuePath="RoleId"/>
        <Button Content="Сохранить" Click="BtnSave_Click" Margin="0,15,0,0"/>
        <Button Content="Отмена" Click="BtnCancel_Click"/>
    </StackPanel>
</Window>
