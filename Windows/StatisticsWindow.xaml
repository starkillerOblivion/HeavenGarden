<Window x:Class="HeavenGarden.Windows.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HeavenGarden.Windows"
        mc:Ignorable="d"
        Title="StatisticsWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBlock x:Name="tbPlantName" FontWeight="Bold" FontSize="16"/>

        <TextBlock Text="Количество изменений статуса:" Margin="0,10,0,0"/>
        <TextBlock x:Name="tbLogCount"/>

        <TextBlock Text="История изменений:" Margin="0,10,0,0"/>
        <ListBox x:Name="lvStatusLogs" Height="150">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="3">
                        <TextBlock Text="{Binding Timestamp, StringFormat='dd.MM.yyyy HH:mm:ss}'}" 
                                   FontWeight="Bold" Foreground="#2E8B57"/>
                        <TextBlock Text="{Binding Details}" TextWrapping="Wrap" Margin="10,0,0,5"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Content="Закрыть" Click="BtnClose_Click" Margin="0,15,0,0" 
                Background="#2E8B57" Foreground="White" Padding="10"/>
    </StackPanel>
</Window>
