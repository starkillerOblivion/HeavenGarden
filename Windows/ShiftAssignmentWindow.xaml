<Window x:Class="HeavenGarden.Windows.ShiftAssignmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HeavenGarden.Windows"
        mc:Ignorable="d"
        Title="ShiftAssignmentWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBlock Text="Садовник:"/>
        <ComboBox x:Name="cmbGardener" DisplayMemberPath="FullName" SelectedValuePath="UserId"/>
        <TextBlock Text="Дата смены:"/>
        <DatePicker x:Name="dpShiftDate"/>
        <TextBlock Text="Начало (чч:мм):"/>
        <TextBox x:Name="tbStartTime"/>
        <TextBlock Text="Конец (чч:мм):"/>
        <TextBox x:Name="tbEndTime"/>
        <TextBlock Text="Примечание:"/>
        <TextBox x:Name="tbNotes"/>
        <Button Content="Сохранить" Click="BtnSave_Click" Margin="0,15,0,0"/>
        <Button Content="Отмена" Click="BtnCancel_Click"/>
    </StackPanel>
</Window>
