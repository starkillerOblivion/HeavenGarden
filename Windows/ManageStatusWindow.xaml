<Window x:Class="HeavenGarden.Windows.ManageStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HeavenGarden.Windows"
        mc:Ignorable="d"
        Title="ManageStatusWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBlock Text="Растение:" FontWeight="Bold"/>
        <TextBlock x:Name="tbPlantName" Margin="0,5,0,10"/>
        <TextBlock Text="Новый статус:"/>
        <TextBox x:Name="tbStatus"/>
        <Button Content="Сохранить" Click="BtnSave_Click" Margin="0,15,0,0"/>
        <Button Content="Отмена" Click="BtnCancel_Click"/>
    </StackPanel>
</Window>
