<Window x:Class="HeavenGarden.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HeavenGarden"
        mc:Ignorable="d"
        Title="MainWindow" Height="550" Width="800">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#8FBC8F" Padding="10">
            <StackPanel HorizontalAlignment="Center">
                <Ellipse Width="80" Height="80">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="/Images/icon.png"/>
                    </Ellipse.Fill>
                </Ellipse>
                <TextBlock Text="Heaven Garden" FontSize="28" FontWeight="Bold" 
                           Foreground="#000000" TextAlignment="Center"/>
                <TextBlock Text="Памятники кактусам, умершим от перелива. Услуги по оплакиванию герани."
                           FontSize="18" Foreground="#2E8B57" 
                           TextAlignment="Center"/>
                <TextBlock Text="📞 +7 (999) 123-45-67 | ⭐ 4.8 (на основе 120 отзывов)"
                           FontSize="14" Foreground="#000000"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <StackPanel DockPanel.Dock="Left" Width="200" Background="#2E8B57" Margin="0,0,10,0">
            <Button Content="Каталог растений" Name="btnCatalog" Click="btnCatalog_Click" Margin="5" Height="40"/>
            <Button Content="Профиль" Name="btnProfile" Click="btnProfile_Click" Margin="5" Height="40"/>
            <Button Content="Мемориальная стена" Name="btnMemorial" Click="btnMemorial_Click" Margin="5" Height="40"/>
            <Button Content="Админ-панель" Name="btnAdmin" Click="btnAdmin_Click" Margin="5" Height="40"/>
            <Button Content="Садовник" Name="btnGardener" Click="btnGardener_Click" Margin="5" Height="40"/>
            <Button Content="Выход" Name="btnExit" Click="btnExit_Click" Margin="5" Height="40"/>
        </StackPanel>

        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" />
    </DockPanel>
</Window>
