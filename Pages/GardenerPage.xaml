<Page x:Class="HeavenGarden.Pages.GardenerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HeavenGarden.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="GardenerPage">

    <TabControl Margin="10">
        <TabItem Header="Заказы">
            <StackPanel>
                <ComboBox x:Name="cmbOrderStatus" SelectionChanged="cmbOrderStatus_SelectionChanged" Margin="5"/>
                <ListBox x:Name="lvOrders" Height="300">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding OrderId}" Width="50"/>
                                <TextBlock Text="{Binding User.FullName}" Width="150"/>
                                <TextBlock Text="{Binding Status}" Width="100"/>
                                <Button Content="Изменить статус" Tag="{Binding OrderId}" Click="BtnChangeStatus_Click" Margin="5,0"/>
                                <Button Content="Контроль качества" Tag="{Binding OrderId}" Click="BtnQualityCheck_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </TabItem>
        <TabItem Header="Смены">
            <StackPanel>
                <Button Content="Назначить смену" Click="BtnAddShift_Click" Margin="5"/>
                <ListBox x:Name="lvShifts" DisplayMemberPath="Notes" Height="200"/>
            </StackPanel>
        </TabItem>
        <TabItem Header="Премии/штрафы">
            <StackPanel>
                <Button Content="Выдать премию/штраф" Click="BtnAddBonusFine_Click" Margin="5"/>
                <ListBox x:Name="lvBonusesFines" Height="200">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Gardener.FullName}" Width="150"/>
                                <TextBlock Text="{Binding Amount, StringFormat={}{0:C}}" Width="80"/>
                                <TextBlock Text="{Binding Reason}" Width="200"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </TabItem>
    </TabControl>
</Page>
