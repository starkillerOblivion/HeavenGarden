<Page x:Class="HeavenGarden.Pages.MemorialWallPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HeavenGarden.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MemorialWallPage">

    <ScrollViewer>
        <ItemsControl x:Name="icMemorial">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#2E8B57" BorderThickness="1" Margin="10" Padding="5" Width="200" CornerRadius="8">
                        <StackPanel>
                            <Image Source="/Images/iconPlant.png" Width="100" Height="100"/>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" TextAlignment="Center" FontSize="16"/>
                            <TextBlock Text="{Binding CauseOfDeath}" FontSize="10" Foreground="Gray" TextAlignment="Center"/>
                            <TextBlock Text="{Binding DeathDate, StringFormat='Ушёл {0:dd.MM.yyyy}'}" FontSize="10"/>
                            <TextBlock Text="🌿 Вечная память 🌿" FontSize="9" FontStyle="Italic" TextAlignment="Center" Foreground="#2E8B57"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</Page>
