<Page x:Class="HeavenGarden.Pages.PlantDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HeavenGarden.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PlantDetailsPage">

    <ScrollViewer>
        <StackPanel Margin="15">
            <TextBlock x:Name="tbName" FontSize="24" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap"/>
            <TextBlock x:Name="tbSpecies" FontSize="16" Margin="0,10,0,0" TextWrapping="Wrap"/>
            <TextBlock x:Name="tbCause" FontSize="14" Foreground="Red" Margin="0,5,0,0" TextWrapping="Wrap"/>
            <TextBlock x:Name="tbDeathDate" FontSize="14" Margin="0,5,0,0"/>
            <TextBlock x:Name="tbOwner" FontSize="14" Margin="0,5,0,0"/>
            <TextBlock Text="📜 История изменений" FontWeight="Bold" FontSize="18" Margin="0,20,0,10"/>
            <ListBox x:Name="lvLogs" Height="200">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="3">
                            <TextBlock Text="{Binding Timestamp, StringFormat='dd.MM.yyyy HH:mm:ss}'}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Details}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </ScrollViewer>
</Page>
