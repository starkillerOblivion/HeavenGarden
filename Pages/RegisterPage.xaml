<Page x:Class="HeavenGarden.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HeavenGarden.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegisterPage">

    <Grid Margin="10">
        <StackPanel VerticalAlignment="Center" Width="350">

            <TextBlock Text="Логин" Margin="0,0,0,5"/>
            <TextBox x:Name="tbLogin" Margin="0,0,0,10"/>

            <TextBlock Text="Пароль" Margin="0,0,0,5"/>
            <PasswordBox x:Name="pbPassword" Margin="0,0,0,10"/>

            <TextBlock Text="Подтверждение пароля" Margin="0,0,0,5"/>
            <PasswordBox x:Name="pbPasswordConfirm" Margin="0,0,0,10"/>

            <TextBlock Text="Email" Margin="0,0,0,5"/>
            <TextBox x:Name="tbEmail" Margin="0,0,0,10"/>

            <TextBlock Text="Полное имя" Margin="0,0,0,5"/>
            <TextBox x:Name="tbFullName" Margin="0,0,0,20"/>

            <Button Content="Зарегистрироваться" Click="BtnRegister_Click" 
                    Background="#2E8B57" Foreground="White" Padding="10" Margin="0,0,0,10"/>
            <TextBlock x:Name="tbError" Foreground="Red" TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
