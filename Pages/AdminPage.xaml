<Page x:Class="HeavenGarden.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HeavenGarden.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminPage">

    <TabControl Margin="10">
        <TabItem Header="Пользователи">
            <StackPanel>
                <Button Content="Добавить пользователя" Name="btnAddUser" Click="btnAddUser_Click" Margin="5"/>
                <ListBox x:Name="lvUsers">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Username}" Width="150"/>
                                <TextBlock Text="{Binding FullName}" Width="200"/>
                                <Button Content="Редактировать" Tag="{Binding UserId}" Name="btnEdit" Click="btnEdit_Click"/>
                                <Button Content="Удалить" Tag="{Binding UserId}" Name="btnDelete" Click="btnDelete_Click" Margin="5,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </TabItem>
        <TabItem Header="Растения">
            <StackPanel>
                <Button Content="Добавить растение" Name="btnAddPlant" Click="btnAddPlant_Click" Margin="5"/>
                <ListBox x:Name="lvPlants">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" Width="150"/>
                                <Button Content="Редактировать" Tag="{Binding PlantId}" Name="btnEditPlant" Click="btnEditPlant_Click"/>
                                <Button Content="Удалить" Tag="{Binding PlantId}" Name="btnDeletePlant" Click="btnDeletePlant_Click" Margin="5,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </TabItem>
        <TabItem Header="Товары">
            <StackPanel>
                <Button Content="Добавить товар" Name="btnAddGood" Click="btnAddGood_Click" Margin="5"/>
                <ListBox x:Name="lvGoods">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" Width="150"/>
                                <Button Content="Редактировать" Tag="{Binding GoodId}" Name="btnEditGood" Click="btnEditGood_Click"/>
                                <Button Content="Удалить" Tag="{Binding GoodId}" Name="btnDeleteGood" Click="btnDeleteGood_Click" Margin="5,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </TabItem>
        <TabItem Header="Услуги">
            <StackPanel>
                <Button Content="Добавить услугу" Name="btnAddService" Click="btnAddService_Click" Margin="5"/>
                <ListBox x:Name="lvServices">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" Width="150"/>
                                <Button Content="Редактировать" Tag="{Binding ServiceId}" Name="btnEditService" Click="btnEditService_Click"/>
                                <Button Content="Удалить" Tag="{Binding ServiceId}" Name="btnDeleteService" Click="btnDeleteService_Click" Margin="5,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </TabItem>
        <TabItem Header="Логи">
            <ListBox x:Name="lvLogs" DisplayMemberPath="Details" Height="400"/>
        </TabItem>
    </TabControl>
</Page>
